generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())

  projects        ProjectMember[]
  installments    Installment[]
  proposedChanges PendingChange[]  @relation("ProposedChanges")
  changeApprovals ChangeApproval[]
  notes           Note[]
  invites         ProjectInvite[]
  negocios        Negocio[]
}

model Project {
  id           String    @id @default(cuid())
  name         String
  description  String?
  developer    String?
  location     String?
  unitNumber   String?
  totalPrice    Float?
  entryPrice    Float
  entryPriceBRL Float?
  currentValue Float
  currency     String    @default("USD")
  status       String    @default("active") // active | sold
  soldPrice    Float?
  soldAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members        ProjectMember[]
  installments   Installment[]
  reinforcements Reinforcement[]
  files          ProjectFile[]
  pendingChanges PendingChange[]
  notes          Note[]
  invites        ProjectInvite[]
}

model ProjectMember {
  id           String @id @default(cuid())
  userId       String
  projectId    String
  role         String @default("member")
  sharePercent Float  @default(100)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Installment {
  id           String    @id @default(cuid())
  projectId    String
  number       Int
  amount       Float
  amountUSD    Float?
  dueDate      DateTime
  paidAt       DateTime?
  paidByUserId String?
  createdAt    DateTime  @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paidBy   User?   @relation(fields: [paidByUserId], references: [id])
}

model Reinforcement {
  id        String    @id @default(cuid())
  projectId String
  amount    Float
  amountUSD Float?
  dueDate   DateTime
  paidAt    DateTime?
  label     String?
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PendingChange {
  id          String   @id @default(cuid())
  projectId   String
  proposedBy  String
  type        String   // "cuota_unmark" | "value_update"
  description String
  payload     String   // JSON string
  status      String   @default("pending") // pending | applied
  createdAt   DateTime @default(now())

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proposer  User             @relation("ProposedChanges", fields: [proposedBy], references: [id])
  approvals ChangeApproval[]
}

model ChangeApproval {
  id              String   @id @default(cuid())
  pendingChangeId String
  userId          String
  createdAt       DateTime @default(now())

  change PendingChange @relation(fields: [pendingChangeId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@unique([pendingChangeId, userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectInvite {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  status    String   @default("pending") // pending | accepted
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  name      String
  path      String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Negocio {
  id           String   @id @default(cuid())
  nombre       String
  inversionUSD Float?
  porcentaje   Float
  userId       String
  createdAt    DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  retiros Retiro[]
}

model Retiro {
  id         String   @id @default(cuid())
  negocioId  String
  fecha      DateTime
  montoARS   Float
  tipoCambio Float
  montoUSD   Float
  nota       String?
  createdAt  DateTime @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
}

model DolarBlue {
  fecha  DateTime @id
  compra Float
  venta  Float
}
